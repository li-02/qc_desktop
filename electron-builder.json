{
    "appId": "com.qcstudio.app",
    "productName": "QC Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "public/dist/**/*",
      "public/frontend/dist/**/*",
      "public/icons/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": ["**/*.py", "**/*.pypots", "**/*.pkl", "**/*.joblib", "requirements.txt"]
      },
      {
        "from": "R-Portable",
        "to": "R",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "public/icons/app-icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "public/icons",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
