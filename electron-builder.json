{
    "appId": "com.yourcompany.qc-desktop",
    "productName": "QC Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "public/dist/**/*",
      "public/frontend/dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": ["**/*.py", "**/*.pypots", "requirements.txt"]
      },
      {
        "from": "R-Portable",
        "to": "R",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }